library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity TopModule_tb is
end TopModule_tb;

architecture behavior of TopModule_tb is

    component TopModule is
        Port (
            clk         : in  std_logic ;
            reset       : in  std_logic ;
            pcoutput      : out std_logic_vector(5 downto 0);
            instruction : out std_logic_vector(31 downto 0)
        );
    end component;
    signal clk         : std_logic := '0';
    signal reset       : std_logic := '1';
    signal pcoutput      : std_logic_vector(5 downto 0);
    signal instruction : std_logic_vector(31 downto 0);

begin

    uut: TopModule
        port map (
            clk         => clk,
            reset       => reset,
            pcoutput      => pcoutput,
            instruction => instruction
        );

    clk_process : process
    begin
        while now < 200 ns loop
            clk <= '0';
            wait for 5 ns;
            clk <= '1';
            wait for 5 ns;
        end loop;
        wait;
    end process;

    reset_process : process
    begin
        reset <= '1';
        wait for 20 ns;
        reset <= '0';
        wait;
    end process;

end behavior;
